{
  "manifest_version": 3,
  "name": "Lebanese Slang Detector",
  "version": "1.0.0",
  "description": "Detects Lebanese drug and weapons slang on any webpage using NLP.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lebanese Slang Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
